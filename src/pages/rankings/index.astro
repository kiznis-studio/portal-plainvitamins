---
import Base from '../../layouts/Base.astro';

const rankings = [
  {
    title: 'Most Common Ingredients',
    href: '/rankings/most-common-ingredients',
    description: 'The top ingredients found across dietary supplements in the NIH DSLD database, ranked by how many products contain them.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
  },
  {
    title: 'Largest Brands',
    href: '/rankings/top-brands',
    description: 'The biggest supplement brands ranked by total number of products registered in the DSLD database.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>`,
  },
  {
    title: 'Newest Supplements',
    href: '/rankings/newest',
    description: 'Recently added dietary supplements currently on the market, sorted by entry date in the NIH database.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
  },
];
---

<Base
  title="Supplement Rankings"
  description="Explore dietary supplement rankings: most common ingredients, largest brands, and newest products from the NIH DSLD database."
  breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'Rankings' }]}
>
  <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-bold mb-3">Supplement Rankings</h1>
    <p class="text-[var(--color-text-secondary)] text-lg mb-10">Explore dietary supplement data ranked by popularity, brand size, and recency.</p>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {rankings.map((r) => (
        <a
          href={r.href}
          class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6 hover:border-[var(--color-primary)] transition-colors"
        >
          <div class="text-[var(--color-primary)] mb-4" set:html={r.icon} />
          <h2 class="text-lg font-semibold mb-2 group-hover:text-[var(--color-primary)] transition-colors">{r.title}</h2>
          <p class="text-sm text-[var(--color-text-secondary)]">{r.description}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
