---
import Base from '../../layouts/Base.astro';
import { getTopBrands } from '../../lib/db';

const db = (Astro.locals as any).runtime.env.DB;
const brands = await getTopBrands(db, 50);
---

<Base
  title="Largest Supplement Brands"
  description="Top 50 dietary supplement brands ranked by number of products in the NIH DSLD database."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Rankings', href: '/rankings/' },
    { name: 'Top Brands' },
  ]}
>
  <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-bold mb-3">Largest Supplement Brands</h1>
    <p class="text-[var(--color-text-secondary)] text-lg mb-10">The top 50 brands with the most dietary supplement products registered in the NIH DSLD database.</p>

    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[var(--color-surface)] border-b border-[var(--color-border)] text-left">
              <th class="px-4 py-3 font-semibold w-16">Rank</th>
              <th class="px-4 py-3 font-semibold">Brand Name</th>
              <th class="px-4 py-3 font-semibold text-right">Products</th>
              <th class="px-4 py-3 font-semibold text-right">On Market</th>
            </tr>
          </thead>
          <tbody>
            {brands.map((brand, i) => (
              <tr class="border-b border-[var(--color-border)] hover:bg-[var(--color-surface)]/80">
                <td class="px-4 py-3 text-[var(--color-text-secondary)]">{i + 1}</td>
                <td class="px-4 py-3">
                  <a href={`/brand/${brand.slug}`} class="text-[var(--color-primary)] hover:underline font-medium">
                    {brand.name}
                  </a>
                </td>
                <td class="px-4 py-3 text-right tabular-nums">{brand.product_count.toLocaleString()}</td>
                <td class="px-4 py-3 text-right tabular-nums">{brand.on_market_count.toLocaleString()}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <p class="text-xs text-[var(--color-text-secondary)] mt-6">Source: NIH Dietary Supplement Label Database (DSLD). "On Market" reflects products not flagged as discontinued.</p>
  </div>
</Base>
