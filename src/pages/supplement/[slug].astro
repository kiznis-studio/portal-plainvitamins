---
import Base from '../../layouts/Base.astro';
import AdSlot from '../../components/ads/AdSlot.astro';
import {
  getProductBySlug,
  getIngredients,
  getProductsByType,
  getProductTypeName,
  formatDV,
  PRODUCT_TYPES,
  type Product,
} from '../../lib/db';

const db = (Astro.locals as any).runtime.env.DB;
const { slug } = Astro.params;

const product = await getProductBySlug(db, slug!);
if (!product) return Astro.redirect('/404');

const ingredients = await getIngredients(db, product.id);

let relatedProducts: Product[] = [];
if (product.product_type_code) {
  const all = await getProductsByType(db, product.product_type_code, 7);
  relatedProducts = all.filter(p => p.id !== product.id).slice(0, 6);
}

const typeName = product.product_type || 'Supplement';
const typeInfo = PRODUCT_TYPES.find(t => t.code === product.product_type_code);
const fmt = (n: number) => n.toLocaleString('en-US');

const supplementSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `${product.name} — Supplement Label Data`,
  description: `${product.name} by ${product.brand || 'Unknown'} — ${typeName} supplement with ${product.ingredient_count} ingredient${product.ingredient_count !== 1 ? 's' : ''}. Label data from the NIH Dietary Supplement Label Database (DSLD).`,
  creator: { '@type': 'Organization', name: 'NIH Office of Dietary Supplements' },
  license: 'https://ods.od.nih.gov/Research/Dietary_Supplement_Label_Database.aspx',
  variableMeasured: ingredients.map(ing => ing.name).slice(0, 20).join(', '),
});

// DV analysis
const highDVIngredients = ingredients.filter(i => i.dv_pct !== null && i.dv_pct >= 100);
const lowDVIngredients = ingredients.filter(i => i.dv_pct !== null && i.dv_pct > 0 && i.dv_pct < 100);
const noDVIngredients = ingredients.filter(i => i.dv_pct === null || i.dv_pct === 0);
const maxDV = ingredients.reduce((max, i) => (i.dv_pct && i.dv_pct > max) ? i.dv_pct : max, 0);
const topIngredient = ingredients.reduce((top, i) => (i.dv_pct && (!top || i.dv_pct > (top.dv_pct || 0))) ? i : top, null as typeof ingredients[0] | null);

// Group ingredients by category
const categoryMap = new Map<string, typeof ingredients>();
for (const ing of ingredients) {
  const cat = ing.category || 'Other';
  if (!categoryMap.has(cat)) categoryMap.set(cat, []);
  categoryMap.get(cat)!.push(ing);
}
const categories = [...categoryMap.entries()].sort((a, b) => b[1].length - a[1].length);

// Title with data
const titleParts = [product.name];
if (product.ingredient_count > 0) titleParts.push(`${product.ingredient_count} Ingredients`);
if (product.brand) titleParts.push(`by ${product.brand}`);
const pageTitle = `${titleParts[0]} — ${titleParts.slice(1).join(', ')} | PlainVitamins`;

// FAQ items
const faqItems = [
  {
    q: `What ingredients are in ${product.name}?`,
    a: `${product.name} contains ${product.ingredient_count} ingredient${product.ingredient_count !== 1 ? 's' : ''}${topIngredient ? `, including ${topIngredient.name}${topIngredient.dv_pct ? ` at ${Math.round(topIngredient.dv_pct)}% Daily Value` : ''}` : ''}. ${categories.length > 1 ? `Ingredients span ${categories.length} categories: ${categories.map(c => c[0]).join(', ')}.` : ''}`,
  },
  {
    q: `Who manufactures ${product.name}?`,
    a: `${product.name} is ${product.off_market ? 'was' : 'currently'} manufactured by ${product.brand || 'an unknown manufacturer'}. It is classified as a ${typeName} supplement${product.physical_state ? ` in ${product.physical_state.toLowerCase()} form` : ''}.`,
  },
  {
    q: `Is ${product.name} still available for purchase?`,
    a: product.off_market
      ? `According to the NIH DSLD database, ${product.name} is listed as off-market and may no longer be available for purchase.`
      : `Yes, ${product.name} is currently listed as on-market in the NIH DSLD database.`,
  },
  {
    q: `What is the serving size of ${product.name}?`,
    a: `The serving size is ${product.serving_size || 'not specified'}${product.servings_per_container ? `, with ${product.servings_per_container} servings per container` : ''}.`,
  },
];
if (highDVIngredients.length > 0) {
  faqItems.push({
    q: `Which ingredients in ${product.name} exceed 100% Daily Value?`,
    a: `${highDVIngredients.length} ingredient${highDVIngredients.length !== 1 ? 's' : ''} exceed${highDVIngredients.length === 1 ? 's' : ''} 100% DV: ${highDVIngredients.slice(0, 5).map(i => `${i.name} (${Math.round(i.dv_pct!)}% DV)`).join(', ')}${highDVIngredients.length > 5 ? `, and ${highDVIngredients.length - 5} more` : ''}.`,
  });
}
faqItems.push({
  q: `Where does this ${product.name} data come from?`,
  a: `All label data comes from the NIH Dietary Supplement Label Database (DSLD), maintained by the Office of Dietary Supplements at the National Institutes of Health. This database catalogs supplement label information for public access.`,
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
});

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Supplements', href: '/supplements/' },
  { name: product.name },
];
---

<Base
  title={pageTitle}
  description={`${product.name} by ${product.brand || 'Unknown'}. ${typeName} supplement with ${product.ingredient_count} ingredients${highDVIngredients.length > 0 ? `, ${highDVIngredients.length} exceeding 100% DV` : ''}. Full label data from NIH DSLD.`}
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={supplementSchema} />
  <script type="application/ld+json" set:html={faqSchema} />

  <div class="max-w-6xl mx-auto px-4 py-8 md:py-12">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-start gap-3 mb-3">
        <h1 class="text-2xl md:text-3xl font-bold">{product.name}</h1>
        <span class:list={[
          'shrink-0 mt-1 px-2 py-0.5 rounded-full text-xs font-medium',
          product.off_market
            ? 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400'
            : 'bg-emerald-50 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-400',
        ]}>
          {product.off_market ? 'Off Market' : 'On Market'}
        </span>
      </div>

      {product.brand && (
        <p class="text-lg text-[var(--color-text-secondary)]">
          by <a href={`/brand/${product.brand.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`} class="text-[var(--color-primary)] hover:underline">{product.brand}</a>
        </p>
      )}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Product Details -->
      <div class="lg:col-span-1">
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6">
          <h2 class="font-semibold mb-4">Product Details</h2>
          <dl class="space-y-3 text-sm">
            {product.product_type && (
              <div>
                <dt class="text-[var(--color-text-secondary)]">Type</dt>
                <dd class="font-medium mt-0.5">
                  <a href={`/supplements/?type=${product.product_type_code}`} class="text-[var(--color-primary)] hover:underline">
                    {typeInfo && <span class="mr-1">{typeInfo.icon}</span>}
                    {product.product_type}
                  </a>
                </dd>
              </div>
            )}
            {product.physical_state && (
              <div>
                <dt class="text-[var(--color-text-secondary)]">Form</dt>
                <dd class="font-medium mt-0.5">{product.physical_state}</dd>
              </div>
            )}
            {product.serving_size && (
              <div>
                <dt class="text-[var(--color-text-secondary)]">Serving Size</dt>
                <dd class="font-medium mt-0.5">{product.serving_size}</dd>
              </div>
            )}
            {product.servings_per_container && (
              <div>
                <dt class="text-[var(--color-text-secondary)]">Servings Per Container</dt>
                <dd class="font-medium mt-0.5">{product.servings_per_container}</dd>
              </div>
            )}
            {product.entry_date && (
              <div>
                <dt class="text-[var(--color-text-secondary)]">Database Entry Date</dt>
                <dd class="font-medium mt-0.5">{product.entry_date}</dd>
              </div>
            )}
            <div>
              <dt class="text-[var(--color-text-secondary)]">Ingredients</dt>
              <dd class="font-medium mt-0.5">{product.ingredient_count}</dd>
            </div>
          </dl>
        </div>
      </div>

      <!-- Ingredients Table -->
      <div class="lg:col-span-2">
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl overflow-hidden">
          <div class="px-6 py-4 border-b border-[var(--color-border)]">
            <h2 class="font-semibold">Supplement Facts ({ingredients.length} Ingredients)</h2>
          </div>

          {ingredients.length > 0 ? (
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-[var(--color-border)]">
                    <th class="text-left px-6 py-3 font-medium text-[var(--color-text-secondary)]">Ingredient</th>
                    <th class="text-left px-4 py-3 font-medium text-[var(--color-text-secondary)]">Group</th>
                    <th class="text-right px-4 py-3 font-medium text-[var(--color-text-secondary)]">Amount</th>
                    <th class="text-right px-6 py-3 font-medium text-[var(--color-text-secondary)]">% DV</th>
                  </tr>
                </thead>
                <tbody>
                  {ingredients.map((ing, i) => (
                    <tr class:list={['border-b border-[var(--color-border)] last:border-0', i % 2 === 0 ? '' : 'bg-[var(--color-bg)]']}>
                      <td class="px-6 py-3 font-medium">{ing.name}</td>
                      <td class="px-4 py-3 text-[var(--color-text-secondary)]">
                        {ing.ingredient_group ? (
                          <a href={`/ingredient/${ing.ingredient_group.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`} class="text-[var(--color-primary)] hover:underline">
                            {ing.ingredient_group}
                          </a>
                        ) : (
                          <span>—</span>
                        )}
                      </td>
                      <td class="px-4 py-3 text-right tabular-nums">
                        {ing.quantity !== null ? `${ing.quantity} ${ing.unit || ''}`.trim() : '—'}
                      </td>
                      <td class="px-6 py-3 text-right tabular-nums">
                        <span class:list={[
                          ing.dv_pct !== null && ing.dv_pct >= 100
                            ? 'font-semibold text-[var(--color-primary)]'
                            : '',
                        ]}>
                          {formatDV(ing.dv_pct)}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="px-6 py-8 text-center text-[var(--color-text-secondary)]">
              No ingredient data available for this product.
            </div>
          )}
        </div>
      </div>
    </div>

    <AdSlot slot="mid" />

    <!-- Related Products -->
    {relatedProducts.length > 0 && (
      <section class="mt-12">
        <h2 class="text-xl font-semibold mb-4">Related {typeName} Products</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {relatedProducts.map(rp => (
            <a href={`/supplement/${rp.slug}`} class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-primary)] transition-colors group">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  <div class="font-semibold group-hover:text-[var(--color-primary)] transition-colors truncate">{rp.name}</div>
                  {rp.brand && (
                    <div class="text-sm text-[var(--color-text-secondary)] mt-1">{rp.brand}</div>
                  )}
                  <div class="text-sm text-[var(--color-text-secondary)] mt-1">
                    {rp.ingredient_count} ingredient{rp.ingredient_count !== 1 ? 's' : ''}
                  </div>
                </div>
                <span class:list={[
                  'shrink-0 px-2 py-0.5 rounded-full text-xs font-medium',
                  rp.off_market
                    ? 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400'
                    : 'bg-emerald-50 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-400',
                ]}>
                  {rp.off_market ? 'Off' : 'On'}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Ingredient Analysis -->
    {categories.length > 1 && (
      <section class="mt-12">
        <h2 class="text-xl font-semibold mb-4">Ingredient Breakdown by Category</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {categories.map(([cat, ings]) => (
            <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-5">
              <div class="font-semibold text-sm text-[var(--color-primary)]">{cat}</div>
              <div class="text-2xl font-bold mt-1">{ings.length}</div>
              <div class="text-sm text-[var(--color-text-secondary)] mt-2">
                {ings.slice(0, 3).map(i => i.name).join(', ')}{ings.length > 3 ? `, +${ings.length - 3} more` : ''}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Daily Value Coverage -->
    {ingredients.length > 0 && (
      <section class="mt-12">
        <h2 class="text-xl font-semibold mb-4">Daily Value Coverage</h2>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
            <div>
              <div class="text-3xl font-bold text-[var(--color-primary)]">{highDVIngredients.length}</div>
              <div class="text-sm text-[var(--color-text-secondary)] mt-1">Above 100% DV</div>
            </div>
            <div>
              <div class="text-3xl font-bold">{lowDVIngredients.length}</div>
              <div class="text-sm text-[var(--color-text-secondary)] mt-1">Below 100% DV</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-[var(--color-text-secondary)]">{noDVIngredients.length}</div>
              <div class="text-sm text-[var(--color-text-secondary)] mt-1">No DV Established</div>
            </div>
          </div>
          {maxDV > 0 && (
            <p class="text-sm text-[var(--color-text-secondary)] mt-4 text-center">
              Highest Daily Value: {topIngredient?.name} at {Math.round(maxDV)}% DV
            </p>
          )}
        </div>
      </section>
    )}

    <!-- Cross-Portal Data -->
    <section class="mt-12">
      <h2 class="text-xl font-semibold mb-4">Related Health Data</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="https://plainmeds.com/" class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-primary)] transition-colors group" target="_blank" rel="noopener">
          <div class="font-semibold group-hover:text-[var(--color-primary)] transition-colors">PlainMeds</div>
          <div class="text-sm text-[var(--color-text-secondary)] mt-1">FDA drug information — check potential supplement-drug interactions</div>
        </a>
        <a href="https://plaindoctor.com/" class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-primary)] transition-colors group" target="_blank" rel="noopener">
          <div class="font-semibold group-hover:text-[var(--color-primary)] transition-colors">PlainDoctor</div>
          <div class="text-sm text-[var(--color-text-secondary)] mt-1">Find healthcare providers for supplement guidance</div>
        </a>
        <a href="https://plainrecalls.com/" class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-primary)] transition-colors group" target="_blank" rel="noopener">
          <div class="font-semibold group-hover:text-[var(--color-primary)] transition-colors">PlainRecalls</div>
          <div class="text-sm text-[var(--color-text-secondary)] mt-1">Check FDA supplement recalls and safety alerts</div>
        </a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mt-12">
      <h2 class="text-xl font-semibold mb-4">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqItems.map(item => (
          <details class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl group">
            <summary class="px-6 py-4 cursor-pointer font-medium hover:text-[var(--color-primary)] transition-colors list-none flex justify-between items-center">
              {item.q}
              <span class="ml-2 text-[var(--color-text-secondary)] group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="px-6 pb-4 text-[var(--color-text-secondary)]">{item.a}</div>
          </details>
        ))}
      </div>
    </section>

    <!-- Data Sources -->
    <section class="mt-12">
      <h2 class="text-lg font-semibold mb-3">Data Sources & Methodology</h2>
      <div class="text-sm text-[var(--color-text-secondary)] space-y-2">
        <p>
          Supplement label data sourced from the <strong>NIH Dietary Supplement Label Database (DSLD)</strong>,
          maintained by the Office of Dietary Supplements at the National Institutes of Health.
          The DSLD contains label information from dietary supplement products marketed in the United States.
        </p>
        <p>
          Daily Value (DV) percentages are based on FDA reference amounts. Products marked "Off Market"
          may no longer be available for purchase but their label data remains in the database for reference.
        </p>
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="mt-10 bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-800 rounded-xl p-4">
      <p class="text-sm text-amber-800 dark:text-amber-200">
        <strong>Disclaimer:</strong> Label data from the NIH Dietary Supplement Label Database (DSLD). This information does not constitute medical advice. Consult a healthcare provider before starting any supplement.
      </p>
    </div>
  </div>
</Base>
